{
    "name": "bluedesert",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "clean": "npx nuxi cleanup && rm -rf node_modules/ && rm -rf .nuxt/ && rm package-lock.json",
        "dev": "nuxt dev",
        "format": "prettier --write \"**/*.{js,json,jsx,css,ts,tsx,vue}\"",
        "format-check": "prettier --check \"**/*.{html,js,json,jsx,css,ts,tsx,vue,scss}\"",
        "generate": "nuxt generate",
        "lint": "eslint .",
        "postinstall": "nuxt prepare",
        "prepare": "simple-git-hooks",
        "preview": "nuxt preview",
        "type-check": "nuxt typecheck"
    },
    "dependencies": {
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/image": "^2.0.0",
        "@nuxt/ui": "^4.8.0",
        "@nuxtjs/i18n": "^10.4.0",
        "@nuxtjs/seo": "^5.1.3",
        "mailgun.js": "^13.1.0",
        "nuxt": "^4.4.6",
        "nuxt-zod-i18n": "^1.12.1",
        "typescript": "^6.0.3",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.0.0",
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@iconify-json/lucide": "^1.2.109",
        "eslint": "^10.4.0",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "simple-git-hooks": "^2.13.1",
        "vue-tsc": "^3.3.2"
    },
    "simple-git-hooks": {
        "commit-msg": "npx commitlint --edit \"$1\"",
        "pre-commit": "npx lint-staged"
    },
    "lint-staged": {
        "*.{html,js,json,css,ts,vue}": "prettier --check",
        "*.{js,ts,vue}": "eslint"
    }
}
